# =============================================================================
# Magic Buyer Letter — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values

# -----------------------------------------------------------------------------
# Supabase (THIS app's database)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Listing Leads SSO (shared secret — get from LL Vercel dashboard)
# -----------------------------------------------------------------------------
CROSS_APP_AUTH_SECRET=base64_shared_secret_from_listing_leads

# -----------------------------------------------------------------------------
# Listing Leads Database (READ-ONLY access to LL profiles)
# -----------------------------------------------------------------------------
LISTING_LEADS_SUPABASE_URL=https://LL_PROJECT.supabase.co
LISTING_LEADS_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_LL_URL=https://listingleads.com

# -----------------------------------------------------------------------------
# RealEstateAPI (property search + skip trace)
# -----------------------------------------------------------------------------
REAPI_KEY=your_reapi_key
REAPI_USER_ID=your_reapi_user_id

# -----------------------------------------------------------------------------
# Lob (address verification + letter printing/mailing)
# -----------------------------------------------------------------------------
LOB_API_KEY=test_xxx
LOB_WEBHOOK_SECRET=your_lob_webhook_secret
LOB_TEMPLATE_ID=tmpl_xxx

# -----------------------------------------------------------------------------
# Anthropic (Claude AI for letter personalization)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# -----------------------------------------------------------------------------
# Stripe (payment for letter sending)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
DEV_LOGIN_ENABLED=true
DEV_USER_EMAIL=dev@localhost.test
